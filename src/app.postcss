@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

@tailwind base;
@tailwind components;
@tailwind utilities;

/* Base styles */
:root {
  --color-primary: theme('colors.primary.500');
  --color-accent: theme('colors.accent.500');
  --color-text: theme('colors.gray.800');
  --color-text-light: theme('colors.gray.600');
  --color-bg: theme('colors.gray.50');
}

body {
  @apply pb-24 bg-gray-50 text-gray-800 font-sans antialiased;
}

h1 {
  @apply text-4xl font-bold;
}

h2 {
  @apply text-3xl font-semibold;
}

h3 {
  @apply text-2xl font-semibold;
}

h4 {
  @apply text-xl font-medium;
}

p {
  @apply text-base leading-relaxed;
}

a {
  @apply text-primary-600 hover:text-primary-800 transition-colors;
}

button {
  @apply focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2;
}
